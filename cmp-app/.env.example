# Database Configuration
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
# URL where the app is hosted (e.g., http://localhost:3000 for local, https://your-domain.com for production)
NEXTAUTH_URL="http://localhost:3000"

# Authentication Provider
# Options: credentials
AUTH_PROVIDER="credentials"

# Storage Provider
# Options: local, gcs (Google Cloud Storage)
STORAGE_PROVIDER="local"

# API Keys
# Anthropic API key for AI features (optional)
ANTHROPIC_API_KEY=""

# Port Configuration
# Defaults to 3000 if not set
# Override in production (e.g., PORT=5000 for GCP)
PORT=3000
