// ============================================================================
// FIX 40: VERSION-AWARE SOURCE MODEL SCHEMA
// ============================================================================
// This file shows the NEW schema design for version-aware sources.
// This is a design document, not the actual schema.prisma file yet.
//
// Key changes:
// 1. Source -> SourceMaster (source family)
// 2. New SourceVersion model (time-specific version)
// 3. SourceItem -> SourceItemVersion (clause versioning)
// 4. New TaskTemplate model (operational task definition)
// 5. Task gets templateId and versionId references
// ============================================================================

// ----------------------------------------------------------------------------
// ENUMS (mostly unchanged, some additions)
// ----------------------------------------------------------------------------

enum SourceType {
  REGULATION
  INDUSTRY_STANDARD
  INTERNAL_AUDIT
  BOARD_DIRECTIVE
  INTERNAL_POLICY
  CONTRACTUAL_OBLIGATION
  REGULATORY_GUIDANCE
}

enum SourceMasterStatus {
  ACTIVE      // Has at least one active version
  ARCHIVED    // No longer in use
}

enum SourceVersionStatus {
  DRAFT       // Being prepared
  ACTIVE      // Currently in effect
  SUPERSEDED  // Replaced by newer version
  ARCHIVED    // Historical record only
}

enum SourceItemChangeType {
  UNCHANGED   // Same as previous version
  MODIFIED    // Changed from previous version
  NEW         // Didn't exist in previous version
  REMOVED     // Existed before but removed
}

enum TaskTemplateStatus {
  DRAFT       // Being configured
  ACTIVE      // Can generate tasks
  RETIRED     // No longer generates tasks
}

enum TaskStatus {
  PLANNED           // Future task, not yet actionable
  TO_DO             // Active and actionable
  IN_PROGRESS       // Work started
  PENDING_REVIEW    // Submitted for review
  COMPLETED         // Finished
  DEFERRED          // Postponed
  NOT_APPLICABLE    // Marked as N/A
}

enum RiskRating {
  HIGH
  MEDIUM
  LOW
}

enum Frequency {
  ADHOC
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  BIENNIAL
  ONE_TIME
}

// ----------------------------------------------------------------------------
// 1. SOURCE MASTER (Replaces current Source for family-level identity)
// ----------------------------------------------------------------------------

model SourceMaster {
  id                   String               @id @default(uuid())
  code                 String               // e.g., "GDPR", "PCI-DSS"
  name                 String               // e.g., "General Data Protection Regulation"
  sourceType           SourceType
  issuingAuthorityId   String?
  ownerTeamId          String
  status               SourceMasterStatus   @default(ACTIVE)
  metadata             Json?                // Extensibility
  
  // Soft delete
  deletedAt            DateTime?
  deletedBy            String?
  deletedReason        String?              @db.Text
  
  // Timestamps
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  
  // Relationships
  issuingAuthority     IssuingAuthority?    @relation(fields: [issuingAuthorityId], references: [id], onDelete: SetNull)
  ownerTeam            Team                 @relation(fields: [ownerTeamId], references: [id], onDelete: Restrict)
  deletedByUser        User?                @relation("SourceMasterDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  versions             SourceVersion[]
  
  // Constraints
  @@unique([code, ownerTeamId])  // Same code can exist across teams
  @@index([ownerTeamId])
  @@index([issuingAuthorityId])
  @@index([status])
  @@index([deletedAt])
  @@index([deletedBy])
}

// ----------------------------------------------------------------------------
// 2. SOURCE VERSION (Time-specific snapshot of a regulation/policy)
// ----------------------------------------------------------------------------

model SourceVersion {
  id                   String                  @id @default(uuid())
  sourceMasterId       String
  versionNumber        String                  // e.g., "1.0", "2023.1", "v4"
  effectiveDate        DateTime                // When this version becomes valid
  expiryDate           DateTime?               // When superseded (nullable if still active)
  reviewDate           DateTime?               // When to review this version
  status               SourceVersionStatus     @default(DRAFT)
  changeSummary        String?                 @db.Text  // Description of changes
  documentUrl          String?                 // Link to official document
  
  // Version chain
  supersedesId         String?                 // Links to previous version
  supersededById       String?                 // Links to next version
  
  // Soft delete
  deletedAt            DateTime?
  deletedBy            String?
  deletedReason        String?                 @db.Text
  
  // Timestamps
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  
  // Relationships
  sourceMaster         SourceMaster            @relation(fields: [sourceMasterId], references: [id], onDelete: Restrict)
  supersedes           SourceVersion?          @relation("VersionSupersession", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy         SourceVersion?          @relation("VersionSupersession")
  deletedByUser        User?                   @relation("SourceVersionDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  
  items                SourceItemVersion[]
  entities             SourceVersionEntity[]   // Which entities this version applies to
  tasks                Task[]                  // Tasks generated from this version
  
  // Business rules enforced by indexes and constraints
  @@unique([sourceMasterId, versionNumber])
  @@unique([sourceMasterId, effectiveDate])  // One version per date per master
  @@index([sourceMasterId])
  @@index([sourceMasterId, status])  // Find active version
  @@index([effectiveDate])
  @@index([status])
  @@index([supersedesId])
  @@index([deletedAt])
  @@index([deletedBy])
}

// ----------------------------------------------------------------------------
// 3. SOURCE VERSION ENTITY (Which entities a version applies to)
// ----------------------------------------------------------------------------

model SourceVersionEntity {
  id              String          @id @default(uuid())
  sourceVersionId String
  entityId        String
  
  sourceVersion   SourceVersion   @relation(fields: [sourceVersionId], references: [id], onDelete: Cascade)
  entity          Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  
  @@unique([sourceVersionId, entityId])
  @@index([sourceVersionId])
  @@index([entityId])
}

// ----------------------------------------------------------------------------
// 4. SOURCE ITEM VERSION (Clause/Article/Control point within a version)
// ----------------------------------------------------------------------------

model SourceItemVersion {
  id                   String                  @id @default(uuid())
  sourceVersionId      String
  reference            String                  // e.g., "Art 5(1)(f)", "Req 8.2"
  title                String
  description          String?                 @db.Text
  parentId             String?                 // For hierarchical structure
  sortOrder            Int                     @default(0)
  
  // Change tracking
  changeType           SourceItemChangeType    @default(NEW)
  previousItemId       String?                 // Link to equivalent item in previous version
  
  metadata             Json?
  
  // Timestamps
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  
  // Relationships
  sourceVersion        SourceVersion           @relation(fields: [sourceVersionId], references: [id], onDelete: Cascade)
  parent               SourceItemVersion?      @relation("ItemHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children             SourceItemVersion[]     @relation("ItemHierarchy")
  previousItem         SourceItemVersion?      @relation("ItemEvolution", fields: [previousItemId], references: [id], onDelete: SetNull)
  nextItems            SourceItemVersion[]     @relation("ItemEvolution")
  
  taskTemplates        TaskTemplate[]
  tasks                Task[]                  // Historical reference
  
  @@index([sourceVersionId])
  @@index([sourceVersionId, reference])  // Find item by reference within version
  @@index([parentId])
  @@index([previousItemId])
  @@index([changeType])
}

// ----------------------------------------------------------------------------
// 5. TASK TEMPLATE (Operational task definition - frequency lives here!)
// ----------------------------------------------------------------------------

model TaskTemplate {
  id                      String                @id @default(uuid())
  sourceItemVersionId     String
  
  // Task definition
  name                    String
  description             String?               @db.Text
  expectedOutcome         String?               @db.Text
  
  // FREQUENCY LIVES HERE, NOT IN SOURCE
  frequency               Frequency
  anchorDate              DateTime              // First occurrence date for recurrence
  
  // Risk and requirements
  riskRating              RiskRating
  evidenceRequired        Boolean               @default(false)
  narrativeRequired       Boolean               @default(false)
  reviewRequired          Boolean               @default(true)
  
  // Default assignments
  defaultResponsibleTeamId String?
  defaultPicId            String?
  defaultReviewerId       String?
  
  // Applicability
  applicableEntities      Json?                 // Array of entity IDs or null for all
  
  // Template lifecycle
  status                  TaskTemplateStatus    @default(DRAFT)
  retiredAt               DateTime?
  retiredReason           String?               @db.Text
  
  // Additional metadata
  clickupUrlTemplate      String?
  gdriveUrlTemplate       String?
  metadata                Json?
  
  // Soft delete
  deletedAt               DateTime?
  deletedBy               String?
  deletedReason           String?               @db.Text
  
  // Timestamps
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  
  // Relationships
  sourceItemVersion       SourceItemVersion     @relation(fields: [sourceItemVersionId], references: [id], onDelete: Restrict)
  defaultResponsibleTeam  Team?                 @relation(fields: [defaultResponsibleTeamId], references: [id], onDelete: SetNull)
  defaultPic              User?                 @relation("TemplateDefaultPIC", fields: [defaultPicId], references: [id], onDelete: SetNull)
  defaultReviewer         User?                 @relation("TemplateDefaultReviewer", fields: [defaultReviewerId], references: [id], onDelete: SetNull)
  deletedByUser           User?                 @relation("TaskTemplateDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  
  generatedTasks          Task[]
  
  @@index([sourceItemVersionId])
  @@index([status])
  @@index([defaultResponsibleTeamId])
  @@index([deletedAt])
  @@index([deletedBy])
}

// ----------------------------------------------------------------------------
// 6. TASK (Generated actionable work item - now with template reference)
// ----------------------------------------------------------------------------

model Task {
  id                   String           @id @default(uuid())
  
  // NEW: Template and version traceability
  taskTemplateId       String           // REQUIRED - which template generated this
  sourceVersionId      String           // REQUIRED - snapshot of source version at creation
  sourceItemVersionId  String           // REQUIRED - snapshot of item version at creation
  
  // Task identity
  name                 String
  description          String?          @db.Text
  expectedOutcome      String?          @db.Text
  
  // Status and classification
  status               TaskStatus       @default(TO_DO)
  riskRating           RiskRating
  frequency            Frequency        // Copied from template at generation
  quarter              String?
  
  // Dates
  dueDate              DateTime?
  plannedDate          DateTime?        // Used for activation logic
  startDate            DateTime?
  testingPeriodStart   DateTime?
  testingPeriodEnd     DateTime?
  
  // Requirements
  evidenceRequired     Boolean          @default(false)
  narrativeRequired    Boolean          @default(false)
  reviewRequired       Boolean          @default(true)
  narrative            String?          @db.Text
  
  // External links
  clickupUrl           String?
  gdriveUrl            String?
  
  // Recurrence tracking
  recurrenceGroupId    String?
  recurrenceIndex      Int?
  recurrenceTotalCount Int?
  
  // Assignment
  entityId             String
  assigneeId           String?
  responsibleTeamId    String?
  picId                String?
  reviewerId           String?
  
  // Workflow timestamps
  submittedAt          DateTime?
  reviewedAt           DateTime?
  completedAt          DateTime?
  
  // Optimistic locking
  version              Int              @default(0)
  
  // Soft delete
  deletedAt            DateTime?
  deletedBy            String?
  deletedReason        String?          @db.Text
  
  // Timestamps
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  
  // Relationships
  taskTemplate         TaskTemplate     @relation(fields: [taskTemplateId], references: [id], onDelete: Restrict)
  sourceVersion        SourceVersion    @relation(fields: [sourceVersionId], references: [id], onDelete: Restrict)
  sourceItemVersion    SourceItemVersion @relation(fields: [sourceItemVersionId], references: [id], onDelete: Restrict)
  entity               Entity           @relation(fields: [entityId], references: [id], onDelete: Restrict)
  assignee             User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  responsibleTeam      Team?            @relation("TaskResponsibleTeam", fields: [responsibleTeamId], references: [id], onDelete: SetNull)
  pic                  User?            @relation("TaskPIC", fields: [picId], references: [id], onDelete: SetNull)
  reviewer             User?            @relation("TaskReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  deletedByUser        User?            @relation("TaskDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  
  evidence             Evidence[]
  comments             Comment[]
  findings             Finding[]
  
  // Indexes for performance
  @@index([taskTemplateId])
  @@index([sourceVersionId])
  @@index([sourceItemVersionId])
  @@index([entityId])
  @@index([assigneeId])
  @@index([responsibleTeamId])
  @@index([picId])
  @@index([reviewerId])
  @@index([recurrenceGroupId])
  @@index([plannedDate])
  @@index([id, version])
  @@index([status])
  @@index([dueDate])
  @@index([completedAt])
  @@index([submittedAt])
  @@index([createdAt])
  @@index([entityId, status])
  @@index([picId, status])
  @@index([responsibleTeamId, status])
  @@index([dueDate, status])
  @@index([deletedAt])
  @@index([deletedBy])
}

// ----------------------------------------------------------------------------
// SUPPORTING MODELS (minimal changes)
// ----------------------------------------------------------------------------

model Entity {
  id                    String                   @id @default(uuid())
  code                  String                   @unique
  name                  String
  shortName             String
  jurisdiction          String
  regulator             String
  isActive              Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  
  userAccess            UserEntityAccess[]
  sourceVersions        SourceVersionEntity[]    // Updated relationship
  tasks                 Task[]
  findings              Finding[]
  auditLogs             AuditLog[]
}

model Team {
  id                       String                @id @default(uuid())
  name                     String                @unique
  description              String?
  approvalRequired         Boolean               @default(true)
  evidenceRequired         Boolean               @default(false)
  narrativeRequired        Boolean               @default(false)
  statusFlow               Json
  isActive                 Boolean               @default(true)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  
  memberships              TeamMembership[]
  sourceMasters            SourceMaster[]        // Updated relationship
  taskTemplates            TaskTemplate[]        // New relationship
  responsibleTasks         Task[]                @relation("TaskResponsibleTeam")
}

model User {
  id                       String                @id @default(uuid())
  email                    String                @unique
  name                     String
  initials                 String
  passwordHash             String
  roleId                   String
  isActive                 Boolean               @default(true)
  avatarColor              String?
  timezone                 String                @default("UTC")
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  
  role                     Role                  @relation(fields: [roleId], references: [id], onDelete: Restrict)
  entityAccess             UserEntityAccess[]
  teamMemberships          TeamMembership[]
  
  // Task relationships
  assignedTasks            Task[]                @relation("TaskAssignee")
  picTasks                 Task[]                @relation("TaskPIC")
  reviewTasks              Task[]                @relation("TaskReviewer")
  deletedTasks             Task[]                @relation("TaskDeleter")
  
  // Task Template relationships (NEW)
  defaultPicTemplates      TaskTemplate[]        @relation("TemplateDefaultPIC")
  defaultReviewerTemplates TaskTemplate[]        @relation("TemplateDefaultReviewer")
  deletedTaskTemplates     TaskTemplate[]        @relation("TaskTemplateDeleter")
  
  // Source relationships (NEW)
  deletedSourceMasters     SourceMaster[]        @relation("SourceMasterDeleter")
  deletedSourceVersions    SourceVersion[]       @relation("SourceVersionDeleter")
  
  // Other relationships
  actionFindings           Finding[]             @relation("FindingActionOwner")
  raisedFindings           Finding[]             @relation("FindingRaisedBy")
  deletedFindings          Finding[]             @relation("FindingDeleter")
  comments                 Comment[]
  uploadedFiles            Evidence[]
  auditLogs                AuditLog[]
  notifications            Notification[]
  errorLogs                ErrorLog[]            @relation("ErrorLogs")
  resolvedErrors           ErrorLog[]            @relation("ResolvedErrors")
  idempotencyKeys          IdempotencyKey[]      @relation("IdempotencyKeys")
}

// Finding model updated to reference SourceVersion instead of Source
model Finding {
  id                 String             @id @default(uuid())
  reference          String             @unique
  title              String
  description        String?            @db.Text
  severity           FindingSeverity
  status             FindingStatus      @default(OPEN)
  rootCause          String?            @db.Text
  impact             String?            @db.Text
  managementResponse String?            @db.Text
  closureNote        String?            @db.Text
  targetDate         DateTime?
  closedAt           DateTime?
  
  // Updated: reference source version instead of source
  sourceVersionId    String
  taskId             String?
  entityId           String
  actionOwnerId      String
  raisedById         String
  
  deletedAt          DateTime?
  deletedBy          String?
  deletedReason      String?            @db.Text
  
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  
  sourceVersion      SourceVersion      @relation(fields: [sourceVersionId], references: [id], onDelete: Restrict)
  task               Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)
  entity             Entity             @relation(fields: [entityId], references: [id], onDelete: Restrict)
  actionOwner        User               @relation("FindingActionOwner", fields: [actionOwnerId], references: [id], onDelete: Restrict)
  raisedBy           User               @relation("FindingRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)
  deletedByUser      User?              @relation("FindingDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  evidence           Evidence[]
  comments           Comment[]
  
  @@index([sourceVersionId])
  @@index([taskId])
  @@index([entityId])
  @@index([actionOwnerId])
  @@index([raisedById])
  @@index([status])
  @@index([severity])
  @@index([targetDate])
  @@index([createdAt])
  @@index([entityId, status])
  @@index([actionOwnerId, status])
  @@index([severity, status])
  @@index([deletedAt])
  @@index([deletedBy])
}

// ============================================================================
// END OF VERSION-AWARE SCHEMA DESIGN
// ============================================================================
