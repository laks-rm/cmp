generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  REGULATION
  INDUSTRY_STANDARD
  INTERNAL_AUDIT
  BOARD_DIRECTIVE
  INTERNAL_POLICY
  CONTRACTUAL_OBLIGATION
  REGULATORY_GUIDANCE
}

enum SourceStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum TaskStatus {
  TO_DO
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  DEFERRED
  NOT_APPLICABLE
}

enum RiskRating {
  HIGH
  MEDIUM
  LOW
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  BIENNIAL
  ONE_TIME
}

enum FindingSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  OBSERVATION
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  IMPLEMENTED
  VERIFIED
  CLOSED
  OVERDUE
}

model Entity {
  id           String             @id @default(uuid())
  code         String             @unique
  name         String
  shortName    String
  jurisdiction String
  regulator    String
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  userAccess   UserEntityAccess[]
  sourceLinks  SourceEntity[]
  tasks        Task[]
  findings     Finding[]
  auditLogs    AuditLog[]
}

model Team {
  id                String           @id @default(uuid())
  name              String           @unique
  description       String?
  approvalRequired  Boolean          @default(true)
  evidenceRequired  Boolean          @default(false)
  narrativeRequired Boolean          @default(false)
  statusFlow        Json
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  memberships       TeamMembership[]
  sources           Source[]
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  displayName String
  description String
  isSystem    Boolean          @default(true)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      String
  description String
  roles       RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  granted      Boolean    @default(false)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model User {
  id              String             @id @default(uuid())
  email           String             @unique
  name            String
  initials        String
  passwordHash    String
  roleId          String
  isActive        Boolean            @default(true)
  avatarColor     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  role            Role               @relation(fields: [roleId], references: [id], onDelete: Restrict)
  entityAccess    UserEntityAccess[]
  teamMemberships TeamMembership[]
  assignedTasks   Task[]             @relation("TaskAssignee")
  picTasks        Task[]             @relation("TaskPIC")
  reviewTasks     Task[]             @relation("TaskReviewer")
  actionFindings  Finding[]          @relation("FindingActionOwner")
  raisedFindings  Finding[]          @relation("FindingRaisedBy")
  comments        Comment[]
  uploadedFiles   Evidence[]
  auditLogs       AuditLog[]
  notifications   Notification[]
}

model UserEntityAccess {
  id       String @id @default(uuid())
  userId   String
  entityId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity   Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
}

model TeamMembership {
  id     String @id @default(uuid())
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model Source {
  id               String       @id @default(uuid())
  code             String
  name             String
  sourceType       SourceType
  issuingAuthority String?
  effectiveDate    DateTime?
  reviewDate       DateTime?
  status           SourceStatus @default(DRAFT)
  teamId           String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  team             Team         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  entities         SourceEntity[]
  items            SourceItem[]
  tasks            Task[]
  findings         Finding[]

  @@unique([code, teamId])
  @@index([teamId])
}

model SourceEntity {
  id       String @id @default(uuid())
  sourceId String
  entityId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  entity   Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([sourceId, entityId])
  @@index([sourceId])
  @@index([entityId])
}

model SourceItem {
  id          String       @id @default(uuid())
  sourceId    String
  reference   String
  title       String
  description String?
  parentId    String?
  sortOrder   Int          @default(0)
  status      String       @default("ACTIVE")
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  source      Source       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  parent      SourceItem?  @relation("SourceItemParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    SourceItem[] @relation("SourceItemParent")
  tasks       Task[]

  @@index([sourceId])
  @@index([parentId])
}

model Task {
  id                 String      @id @default(uuid())
  name               String
  description        String?
  expectedOutcome    String?
  status             TaskStatus  @default(TO_DO)
  riskRating         RiskRating
  frequency          Frequency
  quarter            String?
  dueDate            DateTime?
  startDate          DateTime?
  testingPeriodStart DateTime?
  testingPeriodEnd   DateTime?
  evidenceRequired   Boolean     @default(false)
  narrativeRequired  Boolean     @default(false)
  reviewRequired     Boolean     @default(true)
  narrative          String?
  clickupUrl         String?
  gdriveUrl          String?
  sourceId           String
  sourceItemId       String?
  entityId           String
  assigneeId         String?
  picId              String?
  reviewerId         String?
  submittedAt        DateTime?
  reviewedAt         DateTime?
  completedAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  source             Source      @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  sourceItem         SourceItem? @relation(fields: [sourceItemId], references: [id], onDelete: SetNull)
  entity             Entity      @relation(fields: [entityId], references: [id], onDelete: Restrict)
  assignee           User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  pic                User?       @relation("TaskPIC", fields: [picId], references: [id], onDelete: SetNull)
  reviewer           User?       @relation("TaskReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  evidence           Evidence[]
  comments           Comment[]
  findings           Finding[]

  @@index([sourceId])
  @@index([sourceItemId])
  @@index([entityId])
  @@index([assigneeId])
  @@index([picId])
  @@index([reviewerId])
}

model Evidence {
  id           String   @id @default(uuid())
  taskId       String?
  findingId    String?
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  uploadedById String
  createdAt    DateTime @default(now())
  task         Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  finding      Finding? @relation(fields: [findingId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([findingId])
  @@index([uploadedById])
}

model Finding {
  id                 String          @id @default(uuid())
  reference          String          @unique
  title              String
  description        String?
  severity           FindingSeverity
  status             FindingStatus   @default(OPEN)
  rootCause          String?
  impact             String?
  managementResponse String?
  closureNote        String?
  targetDate         DateTime?
  closedAt           DateTime?
  sourceId           String
  taskId             String?
  entityId           String
  actionOwnerId      String
  raisedById         String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  source             Source          @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  task               Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  entity             Entity          @relation(fields: [entityId], references: [id], onDelete: Restrict)
  actionOwner        User            @relation("FindingActionOwner", fields: [actionOwnerId], references: [id], onDelete: Restrict)
  raisedBy           User            @relation("FindingRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)
  evidence           Evidence[]
  comments           Comment[]

  @@index([sourceId])
  @@index([taskId])
  @@index([entityId])
  @@index([actionOwnerId])
  @@index([raisedById])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  taskId    String?
  findingId String?
  authorId  String
  createdAt DateTime @default(now())
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  finding   Finding? @relation(fields: [findingId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([findingId])
  @@index([authorId])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  module     String
  entityId   String?
  userId     String
  targetType String?
  targetId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  entity     Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityId])
  @@index([module, action])
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  userId    String
  linkUrl   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}
