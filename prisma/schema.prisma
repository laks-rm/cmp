generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  REGULATION
  INDUSTRY_STANDARD
  INTERNAL_AUDIT
  BOARD_DIRECTIVE
  INTERNAL_POLICY
  CONTRACTUAL_OBLIGATION
  REGULATORY_GUIDANCE
}

enum SourceStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// FIX 40: New enums for version-aware source model
enum SourceMasterStatus {
  ACTIVE
  ARCHIVED
}

enum SourceVersionStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

enum SourceItemChangeType {
  UNCHANGED
  MODIFIED
  NEW
  REMOVED
}

enum TaskTemplateStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum TaskStatus {
  PLANNED
  TO_DO
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  DEFERRED
  NOT_APPLICABLE
}

enum RiskRating {
  HIGH
  MEDIUM
  LOW
}

enum Frequency {
  ADHOC
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  BIENNIAL
  ONE_TIME
}

enum FindingSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  OBSERVATION
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  IMPLEMENTED
  VERIFIED
  CLOSED
  OVERDUE
}

model IssuingAuthority {
  id           String   @id @default(uuid())
  name         String   @unique
  abbreviation String?
  country      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sources      Source[]
  sourceMasters SourceMaster[]
}

// ============================================================================
// FIX 40: VERSION-AWARE SOURCE MODEL
// ============================================================================

model SourceMaster {
  id                   String               @id @default(uuid())
  code                 String
  name                 String
  sourceType           SourceType
  issuingAuthorityId   String?
  ownerTeamId          String
  status               SourceMasterStatus   @default(ACTIVE)
  metadata             Json?
  
  // Soft delete fields
  deletedAt            DateTime?
  deletedBy            String?
  deletedReason        String?              @db.Text
  
  // Timestamps
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  
  // Relationships
  issuingAuthority     IssuingAuthority?    @relation(fields: [issuingAuthorityId], references: [id], onDelete: SetNull)
  ownerTeam            Team                 @relation(fields: [ownerTeamId], references: [id], onDelete: Restrict)
  deletedByUser        User?                @relation("SourceMasterDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  versions             SourceVersion[]
  
  // Constraints
  @@unique([code, ownerTeamId])
  @@index([ownerTeamId])
  @@index([issuingAuthorityId])
  @@index([status])
  @@index([deletedAt])
  @@index([deletedBy])
}

model SourceVersion {
  id                   String                  @id @default(uuid())
  sourceMasterId       String
  versionNumber        String
  effectiveDate        DateTime
  expiryDate           DateTime?
  reviewDate           DateTime?
  status               SourceVersionStatus     @default(DRAFT)
  changeSummary        String?                 @db.Text
  documentUrl          String?
  
  // Version chain (many-to-one: many versions can supersede one older version)
  supersedesId         String?
  
  // Soft delete fields
  deletedAt            DateTime?
  deletedBy            String?
  deletedReason        String?                 @db.Text
  
  // Timestamps
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  
  // Relationships
  sourceMaster         SourceMaster            @relation(fields: [sourceMasterId], references: [id], onDelete: Restrict)
  supersedes           SourceVersion?          @relation("VersionSupersession", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy         SourceVersion[]         @relation("VersionSupersession")
  deletedByUser        User?                   @relation("SourceVersionDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  
  items                SourceItemVersion[]
  entities             SourceVersionEntity[]
  tasks                Task[]
  findings             Finding[]
  
  // Constraints
  @@unique([sourceMasterId, versionNumber])
  @@unique([sourceMasterId, effectiveDate])
  @@index([sourceMasterId])
  @@index([sourceMasterId, status])
  @@index([effectiveDate])
  @@index([status])
  @@index([supersedesId])
  @@index([deletedAt])
  @@index([deletedBy])
}

model SourceVersionEntity {
  id              String          @id @default(uuid())
  sourceVersionId String
  entityId        String
  
  sourceVersion   SourceVersion   @relation(fields: [sourceVersionId], references: [id], onDelete: Cascade)
  entity          Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  
  @@unique([sourceVersionId, entityId])
  @@index([sourceVersionId])
  @@index([entityId])
}

model SourceItemVersion {
  id                   String                  @id @default(uuid())
  sourceVersionId      String
  reference            String
  title                String
  description          String?                 @db.Text
  parentId             String?
  sortOrder            Int                     @default(0)
  
  // Change tracking
  changeType           SourceItemChangeType    @default(NEW)
  previousItemId       String?
  
  metadata             Json?
  
  // Timestamps
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  
  // Relationships
  sourceVersion        SourceVersion           @relation(fields: [sourceVersionId], references: [id], onDelete: Cascade)
  parent               SourceItemVersion?      @relation("ItemHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children             SourceItemVersion[]     @relation("ItemHierarchy")
  previousItem         SourceItemVersion?      @relation("ItemEvolution", fields: [previousItemId], references: [id], onDelete: SetNull)
  nextItems            SourceItemVersion[]     @relation("ItemEvolution")
  
  taskTemplates        TaskTemplate[]
  tasks                Task[]
  
  @@index([sourceVersionId])
  @@index([sourceVersionId, reference])
  @@index([parentId])
  @@index([previousItemId])
  @@index([changeType])
}

model TaskTemplate {
  id                      String                @id @default(uuid())
  sourceItemVersionId     String
  
  // Task definition
  name                    String
  description             String?               @db.Text
  expectedOutcome         String?               @db.Text
  
  // Frequency lives here!
  frequency               Frequency
  anchorDate              DateTime
  
  // Risk and requirements
  riskRating              RiskRating
  evidenceRequired        Boolean               @default(false)
  narrativeRequired       Boolean               @default(false)
  reviewRequired          Boolean               @default(true)
  
  // Default assignments
  defaultResponsibleTeamId String?
  defaultPicId            String?
  defaultReviewerId       String?
  
  // Applicability
  applicableEntities      Json?
  
  // Template lifecycle
  status                  TaskTemplateStatus    @default(DRAFT)
  retiredAt               DateTime?
  retiredReason           String?               @db.Text
  
  // Additional metadata
  clickupUrlTemplate      String?
  gdriveUrlTemplate       String?
  metadata                Json?
  
  // Soft delete fields
  deletedAt               DateTime?
  deletedBy               String?
  deletedReason           String?               @db.Text
  
  // Timestamps
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  
  // Relationships
  sourceItemVersion       SourceItemVersion     @relation(fields: [sourceItemVersionId], references: [id], onDelete: Restrict)
  defaultResponsibleTeam  Team?                 @relation("TemplateDefaultTeam", fields: [defaultResponsibleTeamId], references: [id], onDelete: SetNull)
  defaultPic              User?                 @relation("TemplateDefaultPIC", fields: [defaultPicId], references: [id], onDelete: SetNull)
  defaultReviewer         User?                 @relation("TemplateDefaultReviewer", fields: [defaultReviewerId], references: [id], onDelete: SetNull)
  deletedByUser           User?                 @relation("TaskTemplateDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  
  generatedTasks          Task[]
  
  @@index([sourceItemVersionId])
  @@index([status])
  @@index([defaultResponsibleTeamId])
  @@index([deletedAt])
  @@index([deletedBy])
}

model Entity {
  id                String                   @id @default(uuid())
  code              String                   @unique
  name              String
  shortName         String
  jurisdiction      String
  regulator         String
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  userAccess        UserEntityAccess[]
  sourceLinks       SourceEntity[]
  sourceVersions    SourceVersionEntity[]    // FIX 40: New relationship
  tasks             Task[]
  findings          Finding[]
  auditLogs         AuditLog[]
}

model Team {
  id                       String           @id @default(uuid())
  name                     String           @unique
  description              String?
  approvalRequired         Boolean          @default(true)
  evidenceRequired         Boolean          @default(false)
  narrativeRequired        Boolean          @default(false)
  statusFlow               Json
  isActive                 Boolean          @default(true)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  memberships              TeamMembership[]
  sources                  Source[]
  sourceMasters            SourceMaster[]          // FIX 40: New relationship
  taskTemplates            TaskTemplate[]   @relation("TemplateDefaultTeam")  // FIX 40: New relationship
  responsibleTasks         Task[]           @relation("TaskResponsibleTeam")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  displayName String
  description String
  isSystem    Boolean          @default(true)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      String
  description String
  roles       RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  granted      Boolean    @default(false)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model User {
  id                       String             @id @default(uuid())
  email                    String             @unique
  name                     String
  initials                 String
  passwordHash             String
  roleId                   String
  isActive                 Boolean            @default(true)
  avatarColor              String?
  timezone                 String             @default("UTC")
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  role                     Role               @relation(fields: [roleId], references: [id], onDelete: Restrict)
  entityAccess             UserEntityAccess[]
  teamMemberships          TeamMembership[]
  assignedTasks            Task[]             @relation("TaskAssignee")
  picTasks                 Task[]             @relation("TaskPIC")
  reviewTasks              Task[]             @relation("TaskReviewer")
  deletedTasks             Task[]             @relation("TaskDeleter")
  // FIX 40: New relationships
  defaultPicTemplates      TaskTemplate[]     @relation("TemplateDefaultPIC")
  defaultReviewerTemplates TaskTemplate[]     @relation("TemplateDefaultReviewer")
  deletedTaskTemplates     TaskTemplate[]     @relation("TaskTemplateDeleter")
  deletedSourceMasters     SourceMaster[]     @relation("SourceMasterDeleter")
  deletedSourceVersions    SourceVersion[]    @relation("SourceVersionDeleter")
  // Existing relationships
  actionFindings           Finding[]          @relation("FindingActionOwner")
  raisedFindings           Finding[]          @relation("FindingRaisedBy")
  deletedFindings          Finding[]          @relation("FindingDeleter")
  deletedSources           Source[]           @relation("SourceDeleter")
  comments                 Comment[]
  uploadedFiles            Evidence[]
  auditLogs                AuditLog[]
  notifications            Notification[]
  errorLogs                ErrorLog[]         @relation("ErrorLogs")
  resolvedErrors           ErrorLog[]         @relation("ResolvedErrors")
  idempotencyKeys          IdempotencyKey[]   @relation("IdempotencyKeys")
}

model UserEntityAccess {
  id       String @id @default(uuid())
  userId   String
  entityId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity   Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
}

model TeamMembership {
  id     String @id @default(uuid())
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model Source {
  id                   String             @id @default(uuid())
  code                 String             // Source code (e.g., "MFSA-AML-2024", "GDPR")
  name                 String
  sourceType           SourceType
  issuingAuthorityId   String?
  effectiveDate        DateTime?
  reviewDate           DateTime?
  status               SourceStatus       @default(DRAFT)
  teamId               String
  
  // Soft delete fields
  deletedAt            DateTime?
  deletedBy            String?
  deletedReason        String?            @db.Text
  
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  issuingAuthority     IssuingAuthority?  @relation(fields: [issuingAuthorityId], references: [id], onDelete: SetNull)
  team                 Team               @relation(fields: [teamId], references: [id], onDelete: Restrict)
  deletedByUser        User?              @relation("SourceDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  entities             SourceEntity[]
  items                SourceItem[]
  tasks                Task[]
  findings             Finding[]

  // Composite unique constraint: code is unique within a team
  // This allows different teams to use the same source codes independently
  // (e.g., both Compliance and CompOps can have their own "GDPR" source)
  @@unique([code, teamId])
  @@index([teamId])
  @@index([issuingAuthorityId])
  @@index([deletedAt])
  @@index([deletedBy])
}

model SourceEntity {
  id       String @id @default(uuid())
  sourceId String
  entityId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  entity   Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([sourceId, entityId])
  @@index([sourceId])
  @@index([entityId])
}

model SourceItem {
  id          String       @id @default(uuid())
  sourceId    String
  reference   String
  title       String
  description String?
  parentId    String?
  sortOrder   Int          @default(0)
  status      String       @default("ACTIVE")
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  source      Source       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  parent      SourceItem?  @relation("SourceItemParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    SourceItem[] @relation("SourceItemParent")
  tasks       Task[]

  @@index([sourceId])
  @@index([parentId])
}

model Task {
  id                   String      @id @default(uuid())
  // FIX 40: New fields for version-aware model (nullable during migration)
  taskTemplateId       String?
  sourceVersionId      String?
  sourceItemVersionId  String?
  // Existing fields
  name                 String
  description          String?
  expectedOutcome      String?
  status               TaskStatus  @default(TO_DO)
  riskRating           RiskRating
  frequency            Frequency
  quarter              String?
  dueDate              DateTime?
  startDate            DateTime?
  testingPeriodStart   DateTime?
  testingPeriodEnd     DateTime?
  evidenceRequired     Boolean     @default(false)
  narrativeRequired    Boolean     @default(false)
  reviewRequired       Boolean     @default(true)
  narrative            String?
  clickupUrl           String?
  gdriveUrl            String?
  recurrenceGroupId    String?
  recurrenceIndex      Int?
  recurrenceTotalCount Int?
  plannedDate          DateTime?
  sourceId             String      // Legacy field, kept temporarily
  sourceItemId         String?     // Legacy field, kept temporarily
  entityId             String
  assigneeId           String?
  responsibleTeamId    String?
  picId                String?
  reviewerId           String?
  submittedAt          DateTime?
  reviewedAt           DateTime?
  completedAt          DateTime?
  version              Int         @default(0)
  
  // Soft delete fields
  deletedAt            DateTime?
  deletedBy            String?
  deletedReason        String?     @db.Text
  
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  // FIX 40: New relationships
  taskTemplate         TaskTemplate?     @relation(fields: [taskTemplateId], references: [id], onDelete: Restrict)
  sourceVersion        SourceVersion?    @relation(fields: [sourceVersionId], references: [id], onDelete: Restrict)
  sourceItemVersion    SourceItemVersion? @relation(fields: [sourceItemVersionId], references: [id], onDelete: Restrict)
  // Legacy relationships
  source               Source      @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  sourceItem           SourceItem? @relation(fields: [sourceItemId], references: [id], onDelete: SetNull)
  // Existing relationships
  entity               Entity      @relation(fields: [entityId], references: [id], onDelete: Restrict)
  assignee             User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  responsibleTeam      Team?       @relation("TaskResponsibleTeam", fields: [responsibleTeamId], references: [id], onDelete: SetNull)
  pic                  User?       @relation("TaskPIC", fields: [picId], references: [id], onDelete: SetNull)
  reviewer             User?       @relation("TaskReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  deletedByUser        User?       @relation("TaskDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  evidence             Evidence[]
  comments             Comment[]
  findings             Finding[]

  // FIX 40: New indexes
  @@index([taskTemplateId])
  @@index([sourceVersionId])
  @@index([sourceItemVersionId])
  // Legacy indexes
  @@index([sourceId])
  @@index([sourceItemId])
  // Existing indexes
  @@index([entityId])
  @@index([assigneeId])
  @@index([responsibleTeamId])
  @@index([picId])
  @@index([reviewerId])
  @@index([recurrenceGroupId])
  @@index([plannedDate])
  @@index([id, version])
  @@index([status])
  @@index([dueDate])
  @@index([completedAt])
  @@index([submittedAt])
  @@index([createdAt])
  @@index([entityId, status])
  @@index([picId, status])
  @@index([responsibleTeamId, status])
  @@index([dueDate, status])
  @@index([deletedAt])
  @@index([deletedBy])
}

model Evidence {
  id           String   @id @default(uuid())
  taskId       String?
  findingId    String?
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  uploadedById String
  createdAt    DateTime @default(now())
  task         Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  finding      Finding? @relation(fields: [findingId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([findingId])
  @@index([uploadedById])
}

model Finding {
  id                 String          @id @default(uuid())
  reference          String          @unique
  title              String
  description        String?
  severity           FindingSeverity
  status             FindingStatus   @default(OPEN)
  rootCause          String?
  impact             String?
  managementResponse String?
  closureNote        String?
  targetDate         DateTime?
  closedAt           DateTime?
  sourceId           String          // Legacy field, kept temporarily
  sourceVersionId    String?         // FIX 40: New field (nullable during migration)
  taskId             String?
  entityId           String
  actionOwnerId      String
  raisedById         String
  
  // Soft delete fields
  deletedAt          DateTime?
  deletedBy          String?
  deletedReason      String?         @db.Text
  
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  source             Source          @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  sourceVersion      SourceVersion?  @relation(fields: [sourceVersionId], references: [id], onDelete: Restrict)  // FIX 40: New relationship
  task               Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  entity             Entity          @relation(fields: [entityId], references: [id], onDelete: Restrict)
  actionOwner        User            @relation("FindingActionOwner", fields: [actionOwnerId], references: [id], onDelete: Restrict)
  raisedBy           User            @relation("FindingRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)
  deletedByUser      User?           @relation("FindingDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  evidence           Evidence[]
  comments           Comment[]

  @@index([sourceId])
  @@index([sourceVersionId])  // FIX 40: New index
  @@index([taskId])
  @@index([entityId])
  @@index([actionOwnerId])
  @@index([raisedById])
  @@index([status])
  @@index([severity])
  @@index([targetDate])
  @@index([createdAt])
  @@index([entityId, status])
  @@index([actionOwnerId, status])
  @@index([severity, status])
  @@index([deletedAt])
  @@index([deletedBy])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  taskId    String?
  findingId String?
  authorId  String
  createdAt DateTime @default(now())
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  finding   Finding? @relation(fields: [findingId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([findingId])
  @@index([authorId])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  module     String
  entityId   String?
  userId     String
  targetType String?
  targetId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  entity     Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityId])
  @@index([module, action])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model Notification {
  id         String   @id @default(uuid())
  type       String
  title      String
  message    String
  isRead     Boolean  @default(false)
  userId     String
  linkUrl    String?
  entityType String?
  entityId   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([userId, entityType, entityId, type])
  @@index([createdAt])
}

enum ErrorType {
  PAGE_CRASH
  ROUTE_ERROR
  NOT_FOUND
  API_FAILURE
  NETWORK_ERROR
  TIMEOUT
  UNAUTHORIZED
  FORBIDDEN
  COMPONENT_ERROR
  RENDER_ERROR
  DATA_FETCH_FAILED
  DATA_VALIDATION_FAILED
  SAVE_FAILED
  DELETE_FAILED
  UPDATE_FAILED
}

enum ErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model ErrorLog {
  id              String         @id @default(uuid())
  errorType       ErrorType
  errorMessage    String         @db.Text
  errorStack      String?        @db.Text
  errorDigest     String?
  url             String
  userAgent       String?
  userId          String?
  user            User?          @relation("ErrorLogs", fields: [userId], references: [id], onDelete: SetNull)
  httpMethod      String?
  statusCode      Int?
  apiEndpoint     String?
  requestBody     Json?
  environment     String         @default("production")
  appVersion      String?
  severity        ErrorSeverity  @default(ERROR)
  resolved        Boolean        @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  resolver        User?          @relation("ResolvedErrors", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolutionNotes String?        @db.Text
  createdAt       DateTime       @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([errorType])
  @@index([resolved])
  @@index([severity])
}

model IdempotencyKey {
  id        String   @id @default(uuid())
  key       String   @unique
  userId    String
  response  Json
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation("IdempotencyKeys", fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([expiresAt])
  @@index([userId])
}
